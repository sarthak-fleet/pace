---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ScrollProgress from "../components/ScrollProgress.astro";
import MouseSpotlight from "../components/MouseSpotlight.astro";
import CursorFollower from "../components/CursorFollower.astro";
import PageEnhancements from "../components/PageEnhancements.astro";
import { paceCheckoutURL, studioCheckoutURL, paceCheckoutIsMailto } from "../config/commerce";

const description =
  "Pace pricing — three tiers. Try is free (Apple Foundation Models). Pace is $29 one-time (bundled local model stack). Studio is $5/month (hosted Composio routing).";

// Tier data sourced from PROJECT_STATUS.md "Pricing posture (landing)":
//   Try (free) / Pace ($29 one-time) / Studio ($5/mo Composio routing).
// Do NOT invent prices — every value below is anchored to that line.
const tiers = [
  {
    name: "Try",
    price: "Free",
    cadence: "",
    blurb:
      "Runs against Apple's Foundation Models tier on any Mac with Apple Intelligence. The full app — voice, screen reading, actions, meeting notes — at no cost. You'll know within a week if the bundled stack is worth $29.",
    cta: { label: "Download Pace", href: "/download" },
    features: [
      "Apple Foundation Models planner (in-process, zero install)",
      "Push-to-talk voice loop with on-device ASR + TTS",
      "Optional local VLM screen reading (LM Studio)",
      "Action executor — clicks, typing, app/URL opens, calendar, reminders",
      "Meeting notes (pinned local, on-device synthesis)",
      "Thread + episodic memory, screen-watch & app-usage journals",
      "Recipe library + teachable skills",
      "MCP stdio tool bridge (you host the servers)",
    ],
    limits: [
      "No bundled Pace-tuned local model — uses Apple FM or your own LM Studio",
      "Apple Intelligence required (macOS 15+ on supported Apple Silicon)",
    ],
  },
  {
    name: "Pace",
    price: "$29",
    cadence: "one-time",
    blurb:
      "The bundled local model stack — Qwen3-4B planner, Qwen3-VL-4B vision, Qwen3 TTS, Kokoro-82M sidecar — all in-process, no LM Studio needed. One payment, yours forever. Free upgrades including the first Pace-tuned model.",
    cta: { label: paceCheckoutIsMailto ? "Email to buy Pace — $29" : "Buy Pace — $29", href: paceCheckoutURL },
    features: [
      "Everything in Try, plus:",
      "Bundled MLX planner (Qwen3-4B) — no external install",
      "Bundled MLX-VLM (Qwen3-VL-4B) for screen reading",
      "Bundled Qwen3 TTS + Kokoro-82M sidecar",
      "WhisperKit ASR scaffold (opt-in)",
      "Sparkle auto-updates for all future models",
      "30-day no-questions refund",
    ],
    limits: [
      "macOS 14.2+, Apple Silicon, 16 GB RAM minimum (32 GB for bf16)",
      "~8 GB one-time model download into HuggingFace cache",
    ],
  },
  {
    name: "Studio",
    price: "$5",
    cadence: "/month",
    blurb:
      "Only useful if you want me to host the Composio routing instead of running the MCP servers yourself. Most people skip it — add it later or never. Cancel anytime.",
    cta: { label: "Email about Studio", href: studioCheckoutURL },
    features: [
      "Everything in Pace, plus:",
      "Hosted Composio routing (GitHub, Slack, Linear, + bundled catalog)",
      "No need to run stdio MCP servers locally",
      "Managed connector uptime + auth",
    ],
    limits: [
      "Off-device: Composio routing sends tool calls to Composio's servers",
      "Menu-bar capsule tints amber while Studio routing is active",
      "Optional — the app is fully functional without it",
    ],
  },
];

// Product + Offer JSON-LD. One Offer per tier, anchored to the real
// prices in PROJECT_STATUS.md. "Free" tier is price 0.00; Studio is
// 5.00/month; Pace is 29.00 one-time. No invented prices.
const siteOrigin = Astro.site ?? "https://heypace.app";
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Pace",
  description:
    "On-device macOS voice agent that reads your screen and acts with local context. Three tiers: Try (free), Pace ($29 one-time), Studio ($5/month).",
  brand: { "@type": "Brand", name: "Pace" },
  url: new URL("/pricing", siteOrigin).toString(),
  offers: [
    {
      "@type": "Offer",
      name: "Try",
      price: "0.00",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      description:
        "Free tier — runs against Apple Foundation Models. No cost, full app.",
      url: new URL("/download", siteOrigin).toString(),
    },
    {
      "@type": "Offer",
      name: "Pace",
      price: "29.00",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      description:
        "One-time $29 — bundled local model stack (Qwen3-4B planner, VLM, TTS). Free upgrades.",
      url: new URL("/pricing", siteOrigin).toString(),
    },
    {
      "@type": "Offer",
      name: "Studio",
      price: "5.00",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      description:
        "$5/month — hosted Composio routing for MCP connectors. Optional add-on.",
      url: new URL("/pricing", siteOrigin).toString(),
    },
  ],
};
---

<BaseLayout title="Pricing — Pace" description={description} pathname="/pricing">
  <ScrollProgress />
  <MouseSpotlight />
  <CursorFollower />
  <PageEnhancements />

  <script
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
    slot="head"
  />

  <Nav />

  <main class="px-6 pt-32 md:pt-40 pb-24">
    <div class="max-w-5xl mx-auto">
      <!-- ── Hero ─────────────────────────────────────────────── -->
      <p class="text-sm uppercase tracking-widest text-[var(--color-text-muted)] font-mono mb-6">
        Pricing
      </p>

      <h1 class="pace-display text-4xl md:text-6xl text-white mb-10 max-w-3xl">
        Three tiers. <em>One is free.</em> One is $29 once. One is optional.
      </h1>

      <div class="pace-prose mb-20">
        <p>
          Pace is fully on-device — the inference costs nothing to run, so
          there's no per-turn bill to pass on. The $29 license pays for the
          bundled local model stack that ships inside the app. Studio is a
          hosted-routing convenience for people who don't want to run MCP
          servers themselves. Most users never need it.
        </p>
        <p>
          Try the whole app free first. If your Mac has Apple Intelligence,
          Pace runs against Apple's Foundation Models at no cost. Buy the $29
          license only after you've decided the bundled stack is worth it.
        </p>
      </div>

      <!-- ── Tier table ───────────────────────────────────────── -->
      <div class="grid md:grid-cols-3 gap-6 mb-20">
        {
          tiers.map((tier) => (
            <div class="pace-card p-8 flex flex-col">
              <div class="mb-6">
                <h2 class="pace-display text-2xl text-white mb-2">{tier.name}</h2>
                <div class="flex items-baseline gap-2">
                  <span class="pace-display text-4xl text-white">{tier.price}</span>
                  {tier.cadence && (
                    <span class="text-sm text-[var(--color-text-muted)]">{tier.cadence}</span>
                  )}
                </div>
              </div>

              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
                {tier.blurb}
              </p>

              <a
                href={tier.cta.href}
                class={tier.name === "Pace" ? "pace-cta-primary text-sm mb-6" : "pace-cta-secondary text-sm mb-6"}
              >
                {tier.cta.label}
                <span aria-hidden="true">→</span>
              </a>

              <div class="border-t border-[var(--color-border-subtle)] pt-5 mb-5">
                <p class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-3">
                  Includes
                </p>
                <ul class="space-y-2 text-sm text-[var(--color-text-secondary)]">
                  {tier.features.map((f) => (
                    <li class="flex gap-2">
                      <span class="text-[var(--color-positive)] shrink-0" aria-hidden="true">✓</span>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="border-t border-[var(--color-border-subtle)] pt-5 mt-auto">
                <p class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-3">
                  Limits
                </p>
                <ul class="space-y-2 text-sm text-[var(--color-text-muted)]">
                  {tier.limits.map((l) => (
                    <li class="flex gap-2">
                      <span class="text-[var(--color-text-muted)] shrink-0" aria-hidden="true">—</span>
                      <span>{l}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>

      <!-- ── Honesty notes ────────────────────────────────────── -->
      <section class="border-t border-[var(--color-border-subtle)] pt-16">
        <p class="text-sm uppercase tracking-widest text-[var(--color-text-muted)] font-mono mb-6">
          The fine print, stated plainly
        </p>

        <div class="pace-prose space-y-5">
          <p>
            <strong>30-day refund.</strong> No questions. The license
            deactivates, your card gets the money back. I don't ask why — I
            already know: the model wasn't a fit, or the download hurt more
            than you wanted. Both are valid.
          </p>
          <p>
            <strong>Free upgrades.</strong> When the first Pace-tuned model
            ships (sometime in the next two quarters, no exact date) the price
            for new buyers goes to $49. If you bought at $29 you keep getting
            the new models free, by way of the same Sparkle updater every other
            Mac app uses.
          </p>
          <p>
            <strong>Studio is optional.</strong> It only routes MCP tool calls
            through Composio's hosted connectors. The app is fully functional
            without it — you can run the same stdio MCP servers locally for
            free. Studio exists for people who'd rather not.
          </p>
          <p>
            <strong>Checkout.</strong>{" "}
            {paceCheckoutIsMailto ? (
              <>Stripe checkout lands soon — today purchases go through email and I'll send a license key manually within a day.</>
            ) : (
              <>Stripe checkout is live.</>
            )}
          </p>
        </div>

        <p class="pace-margin-note mt-12 max-w-md">
          macOS 14+, Apple Silicon, 16 GB RAM minimum.<br />
          32 GB if you want the bigger bf16 model loaded all the time —
          otherwise the 4-bit variant is one Settings toggle away.
        </p>
      </section>

      <!-- ── CTA ──────────────────────────────────────────────── -->
      <section class="text-center mt-32">
        <p class="pace-display text-2xl md:text-3xl text-white mb-8 max-w-xl mx-auto">
          Want to know what you're buying <em>before</em> you buy it?
        </p>
        <a href="/" class="pace-cta-secondary">
          See what Pace does
          <span aria-hidden="true">→</span>
        </a>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
