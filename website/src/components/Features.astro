---
// Features as a long-form bulleted list with marginalia, NOT a
// three-card grid. Each feature is a verb + sentence + technical
// aside in the right margin. Reads like a feature article, not a
// spec sheet.
const features = [
  {
    verb: "Listens",
    body: "Hold ctrl+option, say something, let go. Push-to-talk via a system-wide CGEvent tap. The first spoken word back arrives in about 420 milliseconds.",
    margin: "Apple Speech by default. WhisperKit-Large if you put the model on disk — Pace picks it up automatically.",
  },
  {
    verb: "Looks",
    body: "Ask about what's on your screen. Pace runs a local vision model + Apple Vision OCR + the macOS Accessibility tree in parallel, merges them into one element map, and hands the result to the planner.",
    margin: "Qwen3-VL-4B locally. Same model the LM Studio path used to host — now in-process, no max-loaded-models setting to wrestle with.",
  },
  {
    verb: "Clicks",
    body: "\"Click submit,\" \"snap this window left,\" \"add this to my calendar.\" Pace executes through Accessibility — the right way to drive a Mac — and falls back to CGEvent only when AX can't find the element.",
    margin: "Every reversible change leaves a 5-second undo banner. Tap to roll back.",
  },
  {
    verb: "Remembers",
    body: "Tell it once that you use Firefox, that your design doc is the pinned tab in Arc, that Alex is the engineer not the designer. It carries that across sessions, across quits, across reboots.",
    margin: "Two-tier memory: last four turns verbatim, everything older rolls into a summary. One JSON file, your home directory, your eyes only.",
  },
  {
    verb: "Connects",
    body: "Calendar, Reminders, Notes, Mail, Things, Shortcuts, Messages — first-class, through EventKit and AppleScript. Anything beyond Apple's native data goes through Composio's OAuth gateway when you choose to enable it.",
    margin: "Apple-native stays local. External SaaS is your choice, off by default.",
  },
  {
    verb: "Upgrades",
    body: "When I ship a Pace-tuned model that beats the off-the-shelf default, it comes through the same Sparkle updater every other Mac app uses. No re-purchase. No upgrade wall. Models live in your HuggingFace cache.",
    margin: "Current default is Qwen3-4B-Instruct-2507 bf16. The next one will have a name with `pace-` in front of it.",
  },
];
---

<section id="what-it-does" class="px-6 py-24 md:py-36 border-t border-[var(--color-border-subtle)]">
  <div class="max-w-5xl mx-auto">
    <p class="text-sm uppercase tracking-widest text-[var(--color-text-muted)] font-mono mb-6">
      What it does
    </p>

    <h2 class="pace-display text-4xl md:text-6xl text-white mb-16 max-w-3xl">
      Six verbs. <em>That's the whole product.</em>
    </h2>

    <div class="space-y-16 md:space-y-20">
      {
        features.map((feature, index) => (
          <div class="grid md:grid-cols-[8rem_1fr_14rem] gap-4 md:gap-10 items-start">
            <p class="text-sm font-mono text-[var(--color-text-muted)] tabular-nums pt-3">
              {String(index + 1).padStart(2, "0")}
            </p>

            <div>
              <h3 class="pace-display text-3xl md:text-4xl text-white mb-3">
                <em>{feature.verb}.</em>
              </h3>
              <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-xl">
                {feature.body}
              </p>
            </div>

            <p class="pace-margin-note md:border-l md:border-[var(--color-border-subtle)] md:pl-4 md:mt-3">
              {feature.margin}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
