---
// One competitor's analysis block — the stack row, "what it's good at"
// list, "where Pace differs" callout, and the license/posture side card.
//
// This is the single rendering of a competitor's analysis. Both the
// /compared hub and each dedicated /compared/<slug> page render through
// this component, so the copy exists in exactly one place and can't
// drift between the two surfaces.
import {
  anchorIdForCompetitorName,
  type Competitor,
} from "../config/competitors";

interface Props {
  competitor: Competitor;
  /**
   * On the hub, each block links to its dedicated page ("Full comparison →").
   * On the dedicated page itself, that link is redundant, so it's hidden.
   */
  showFullComparisonLink?: boolean;
}

const { competitor, showFullComparisonLink = false } = Astro.props;

// Anchor id equals the authored slug; derive from the name as a
// belt-and-suspenders guard so a mistyped slug still lands somewhere sane.
const anchorId = anchorIdForCompetitorName(competitor.name);

const postureColor: Record<string, string> = {
  "on-device": "var(--color-positive)",
  cloud: "var(--color-warning)",
  hybrid: "var(--color-text-secondary)",
};

const licenseColor: Record<string, string> = {
  MIT: "var(--color-positive)",
  "Apache-2.0": "var(--color-positive)",
  "Source-available": "var(--color-warning)",
  Proprietary: "var(--color-text-muted)",
  "No license yet": "var(--color-warning)",
};
---

<article id={anchorId} class="scroll-mt-28">
  <div class="grid md:grid-cols-[1fr_16rem] gap-6 md:gap-12 items-start">
    {/* Main column */}
    <div>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
        <h3 class="pace-display text-2xl md:text-3xl text-white">
          {competitor.name}
        </h3>
        <a
          href={competitor.url}
          class="text-sm text-[var(--color-text-muted)] hover:text-white transition-colors underline decoration-[var(--color-border-subtle)] underline-offset-4"
          target="_blank"
          rel="noopener noreferrer"
        >
          {competitor.url.replace(/^https?:\/\//, "").replace(/\/$/, "")}
        </a>
      </div>
      <p class="text-[var(--color-text-secondary)] italic mb-6 max-w-xl">
        {competitor.tagline} — <span class="not-italic text-[var(--color-text-muted)]">{competitor.author}</span>
      </p>

      {/* Stack row */}
      <div class="flex flex-wrap gap-x-5 gap-y-1 text-xs font-mono text-[var(--color-text-muted)] mb-6">
        <span><span class="text-[var(--color-text-secondary)]">STT</span> · {competitor.stt}</span>
        <span><span class="text-[var(--color-text-secondary)]">Reasoner</span> · {competitor.reasoner}</span>
        <span><span class="text-[var(--color-text-secondary)]">TTS</span> · {competitor.tts}</span>
        <span>
          <span class="text-[var(--color-text-secondary)]">Screen</span> · {competitor.screenAware ? "yes" : "no"}
        </span>
      </div>

      {/* Standout features */}
      <p class="text-sm font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-3">
        What it's good at
      </p>
      <ul class="pace-prose list-none p-0 space-y-2 mb-8">
        {competitor.standoutFeatures.map((feature) => (
          <li class="pl-5 relative">
            <span class="absolute left-0 top-[0.55em] w-2 h-px bg-[var(--color-accent)]" />
            {feature}
          </li>
        ))}
      </ul>

      {/* Pace differs */}
      <div class="border-l-2 border-[var(--color-accent)] pl-5 py-1">
        <p class="text-sm font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-2">
          Where Pace differs
        </p>
        <p class="text-[var(--color-text-secondary)] leading-relaxed">
          {competitor.paceDiffers}
        </p>
      </div>

      {
        showFullComparisonLink && (
          <a
            href={`/compared/${competitor.slug}`}
            class="inline-flex items-center gap-2 mt-6 text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
          >
            Full comparison — Pace vs {competitor.name}
            <span aria-hidden="true">→</span>
          </a>
        )
      }
    </div>

    {/* Marginalia column — license + posture card */}
    <aside class="pace-card p-5 md:sticky md:top-24">
      <div class="space-y-4 text-sm">
        <div>
          <p class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-1">
            Open source
          </p>
          <p class="text-white">
            {competitor.openSource ? "Yes" : "No"}
          </p>
        </div>
        <div>
          <p class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-1">
            License
          </p>
          <p style={`color: ${licenseColor[competitor.license]}`}>
            {competitor.license}
          </p>
        </div>
        <div>
          <p class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-1">
            Posture
          </p>
          <p style={`color: ${postureColor[competitor.posture]}`}>
            {competitor.posture}
          </p>
        </div>
      </div>
    </aside>
  </div>
</article>
