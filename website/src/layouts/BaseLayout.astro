---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname?: string;
}

const { title, description, pathname = "/" } = Astro.props;
const canonicalURL = new URL(pathname, Astro.site ?? "https://heypace.app").toString();
const ogImageURL = new URL("/og-image.png", Astro.site ?? "https://heypace.app").toString();

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph: thumbnail-first per the fleet landing standard. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Inter + Instrument Serif — non-blocking so LCP text paints on
         first HTML+CSS, not after two font stylesheets resolve. -->
    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://rsms.me/inter/inter.css"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      />
    </noscript>

    <!-- Per-page <head> extras (e.g. a page-specific BreadcrumbList). -->
    <slot name="head" />
  <!-- fleet-jsonld:start (generated by apply-agent-surfaces; edit registry, not this) -->
<script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://sassmaker.com/#org","name":"SaaS Maker (Foundry)","url":"https://sassmaker.com","sameAs":["https://sassmaker.com","https://github.com/HeyPace/pace"]},{"@type":"SoftwareApplication","@id":"https://heypace.app/#app","name":"Pace","url":"https://heypace.app","description":"On-device Mac voice agent that reads your screen and acts with local context.","publisher":{"@id":"https://sassmaker.com/#org"},"applicationCategory":"UtilitiesApplication","offers":{"@type":"Offer","price":"29.00","priceCurrency":"USD","availability":"https://schema.org/InStock"}}]}</script>
<!-- fleet-jsonld:end -->
</head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
