---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname?: string;
}

const { title, description, pathname = "/" } = Astro.props;
const canonicalURL = new URL(pathname, Astro.site ?? "https://pace.app").toString();
const ogImageURL = new URL("/og-image.png", Astro.site ?? "https://pace.app").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph: thumbnail-first per the fleet landing standard. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Inter for body; Instrument Serif for editorial display
         headlines — the serif is what shifts the whole page from
         "generic dark Tailwind landing" to "someone designed this
         on purpose." Free via Google Fonts. -->
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
    />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
